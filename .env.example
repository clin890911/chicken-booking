# 複製本檔為 .env.local，填入真實值
# .env.local 已在 .gitignore，不會被 commit

# ===== 管理員白名單 (逗號分隔) =====
VITE_ADMIN_EMAILS=berrylin0911@gmail.com

# ===== 角色映射 (JSON 字串) =====
# 沒列在這裡的 email 預設為 floor 外場
VITE_ROLE_MAP={"berrylin0911@gmail.com":"manager"}

# ===== Firebase（v2 切換時才需要，目前 LocalStorage 階段可空白）=====
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ===== Cloud Functions（Firestore 正式資料同步 / 客人查詢）=====
VITE_FUNCTION_BASE_URL=https://us-central1-chicken-booking-tw.cloudfunctions.net

# ===== Telegram 通知 + 備份 =====
# 在 https://t.me/BotFather 建 bot，取得 token
# chat_id 可在後台設定頁自動偵測（先到 t.me/<bot> 按 Start）
VITE_TELEGRAM_BOT_TOKEN=
